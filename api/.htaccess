Options -MultiViews
RewriteEngine On

RewriteRule ^health/?$ health/index.php [L,QSA]
RewriteRule ^categories/?$ categories/index.php [L,QSA]
RewriteRule ^stories/?$ stories/index.php [L,QSA]
RewriteRule ^jobs/?$ jobs/index.php [L,QSA]
RewriteRule ^pipeline/run/?$ pipeline/run/index.php [L,QSA]
RewriteRule ^analytics/read-click/?$ analytics/read-click/index.php [L,QSA]
RewriteRule ^analytics/read-stats/?$ analytics/read-stats/index.php [L,QSA]
